# Copy this file to `.env` for local development. Never commit `.env`.

# Required
DJANGO_SECRET_KEY=django-insecure-dev-only-change-me-in-production-1234567890
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# In production, restrict to your real domain(s):
# DJANGO_ALLOWED_HOSTS=seth-grant.up.railway.app,seth-grant.onrender.com,sethgrant.dev
# DJANGO_CSRF_TRUSTED_ORIGINS=https://seth-grant.up.railway.app,https://seth-grant.onrender.com

# Optional: managed Postgres (Railway / Render). If unset, SQLite is used.
# DATABASE_URL=postgres://user:password@host:5432/dbname

# Optional: contact-form SMTP. If unset, the form falls back to a friendly
# message and the page still shows the mailto link.
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=you@example.com
# EMAIL_HOST_PASSWORD=app-password
# CONTACT_EMAIL=sethngrant2003@gmail.com
# DEFAULT_FROM_EMAIL=Seth Grant Portfolio <noreply@example.com>

